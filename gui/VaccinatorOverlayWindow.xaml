<Window x:Class="MedicAIGUI.VaccinatorOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vaccinator Overlay" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True" ShowInTaskbar="False">
    <Grid Margin="10" VerticalAlignment="Top" HorizontalAlignment="Right">
        <Border Background="#AA000000" CornerRadius="8" Padding="8">
            <StackPanel Orientation="Horizontal">
                <Image x:Name="ResistIcon" Width="32" Height="32" />
                <TextBlock x:Name="ResistText" Foreground="White" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>