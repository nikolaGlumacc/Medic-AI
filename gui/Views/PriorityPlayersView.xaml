<UserControl x:Class="MedicAIGUI.Views.PriorityPlayersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- HEADER -->
        <Grid Margin="0,0,0,20">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="TARGET PLAYER" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Configure a specific player for the bot to follow and heal exclusively." 
                           Style="{StaticResource MicroLabel}" Margin="0,4,0,0"/>
            </StackPanel>
            <WrapPanel HorizontalAlignment="Right">
                <Button Content="Sync to Bot" Width="130" Height="38" Margin="0,0,10,0"
                        Style="{StaticResource SuccessBtn}" Click="SyncBtn_Click"/>
                <Button Content="Clear Target" Width="100" Height="38"
                        Style="{StaticResource DangerBtn}" Click="ClearTargetBtn_Click"/>
            </WrapPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Border Grid.Row="1" Background="#101826" CornerRadius="18" Padding="30" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="CURRENT TARGET" FontWeight="Bold" FontSize="16" Margin="0,0,0,14"/>
                <TextBlock Text="PLAYER IN-GAME NAME (CASE SENSITIVE)" Style="{StaticResource MicroLabel}"/>
                <TextBox x:Name="TargetNameBox" Margin="0,10,0,20" Height="45" FontSize="18" Padding="10,0" KeyDown="TargetNameBox_KeyDown"/>

                <TextBlock Text="BEHAVIOR" FontWeight="Bold" FontSize="16" Margin="0,20,0,14"/>
                <TextBlock Text="1. The bot will use OCR to match the name at its crosshair." Opacity="0.7" Margin="0,0,0,5"/>
                <TextBlock Text="2. If the target dies, the bot will automatically retreat." Opacity="0.7" Margin="0,0,0,5"/>
                <TextBlock Text="3. Ensure the name exactly matches the TF2 scoreboard." Opacity="0.7"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
