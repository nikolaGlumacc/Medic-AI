<UserControl x:Class="MedicAIGUI.Views.TuningView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,15,0">
            <StackPanel Margin="10,0,10,20">
                
                <!-- ── HEADER ────────────────────────────────────────────────── -->
                <Grid Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="NEURAL ENGINE TUNING" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,5,0"/>
                        <TextBlock Text="Fine-tune the behavioral decision-making matrix and sync profiles." Style="{StaticResource MicroLabel}"/>
                    </StackPanel>
                    <Button Content="SYNC TUNING NODE" Click="Sync_Click" Style="{StaticResource SuccessBtn}" Height="42" HorizontalAlignment="Right" Width="200"/>
                </Grid>

                <!-- ── BEHAVIORAL PRESETS ────────────────────────────────────── -->
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="24" Padding="30" Margin="0,0,0,20" BorderBrush="#15FFFFFF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Margin="0,0,30,0">
                            <TextBlock Text="◈  TACTICAL BEHAVIOR PROFILES" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Select a pre-configured neural model for immediate deployment." Style="{StaticResource MicroLabel}" Margin="0,0,0,20"/>
                            
                            <ComboBox x:Name="ProfileSelector" Height="45" SelectionChanged="ProfileSelector_SelectionChanged">
                                <ComboBoxItem Content="Balanced (Operational Baseline)"/>
                                <ComboBoxItem Content="Aggressive (Frontline Pocket)"/>
                                <ComboBoxItem Content="Defensive (Triage Priority)"/>
                                <ComboBoxItem Content="Stealth (Infiltrator Support)"/>
                            </ComboBox>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#0C121B" CornerRadius="18" Padding="20" BorderBrush="#11FFFFFF" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="ACTIVE TOGGLES" Style="{StaticResource MicroLabel}" Margin="0,0,0,12"/>
                                <CheckBox x:Name="CbMirrorMovement" Content="MIRROR STRAFING" IsChecked="True"/>
                                <CheckBox x:Name="CbJumpSync" Content="JUMP SYNCHRONIZATION" IsChecked="True"/>
                                <CheckBox x:Name="CbCrouchSync" Content="CROUCH SYNCHRONIZATION" IsChecked="False"/>
                                <CheckBox x:Name="CbSpyWatch" Content="SMART SPY DEFENSE" IsChecked="True"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── THRESHOLD GRID ────────────────────────────────────────── -->
                <UniformGrid Columns="2">
                    <!-- LEFT: RESPONSE VALUES -->
                    <Border Background="{StaticResource BgCardBrush}" CornerRadius="24" Padding="25" Margin="0,0,10,0" BorderBrush="#15FFFFFF" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="⚡  RESPONSE THRESHOLDS" Style="{StaticResource SectionTitle}" Margin="0,0,0,20"/>

                            <TextBlock Text="RETREAT HP THRESHOLD" Style="{StaticResource MicroLabel}"/>
                            <DockPanel Margin="0,0,0,15">
                                <TextBlock Text="{Binding ElementName=SldRetreatHP, Path=Value, StringFormat={}{0:0}}" DockPanel.Dock="Right" Width="40" TextAlignment="Right" Foreground="{StaticResource AccentHotBrush}" FontWeight="Bold"/>
                                <Slider x:Name="SldRetreatHP" Minimum="20" Maximum="149" Value="45"/>
                            </DockPanel>

                            <TextBlock Text="NEURAL AGGRESSION (0–10)" Style="{StaticResource MicroLabel}"/>
                            <DockPanel Margin="0,0,0,15">
                                <TextBlock Text="{Binding ElementName=SldAggression, Path=Value, StringFormat={}{0:0}}" DockPanel.Dock="Right" Width="40" TextAlignment="Right" Foreground="{StaticResource AccentCoolBrush}" FontWeight="Bold"/>
                                <Slider x:Name="SldAggression" Minimum="0" Maximum="10" Value="3"/>
                            </DockPanel>

                            <TextBlock Text="SPY DETECTION SENSITIVITY" Style="{StaticResource MicroLabel}"/>
                            <Slider x:Name="SldSpySens" Minimum="0" Maximum="10" Value="5" Margin="0,0,0,15"/>
                        </StackPanel>
                    </Border>

                    <!-- RIGHT: SPACING & RADIUS -->
                    <Border Background="{StaticResource BgCardBrush}" CornerRadius="24" Padding="25" Margin="10,0,0,0" BorderBrush="#15FFFFFF" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📍  MOTION &amp; SPACING" Style="{StaticResource SectionTitle}" Margin="0,0,0,20"/>

                            <TextBlock Text="TRAILING BUFFER (PX)" Style="{StaticResource MicroLabel}"/>
                            <Slider x:Name="SldFollowFwd" Minimum="50" Maximum="600" Value="200" Margin="0,0,0,20"/>

                            <TextBlock Text="POCKET PRIORITY RADIUS" Style="{StaticResource MicroLabel}"/>
                            <Slider x:Name="SldPocketRadius" Minimum="100" Maximum="1000" Value="350" Margin="0,0,0,20"/>

                            <TextBlock Text="JUMP SYNC TOLERANCE (MS)" Style="{StaticResource MicroLabel}"/>
                            <TextBox x:Name="TxtJumpTolerance" Text="80" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
