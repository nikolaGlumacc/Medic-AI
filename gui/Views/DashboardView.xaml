<UserControl x:Class="MedicAIGUI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1.8*"/>
        </Grid.ColumnDefinitions>

        <!-- CONNECTION + DEPLOY -->
        <Border Grid.Row="0" Grid.Column="0" Background="#101826" CornerRadius="18" Padding="20" Margin="0,0,16,16">
            <StackPanel>
                <TextBlock Text="Connection" FontWeight="Bold" FontSize="18" Margin="0,0,0,12"/>

                <!-- START / STOP deploy row -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="StartBotBtn" Content="▶  DEPLOY BOT" Height="44"
                            Background="#39D98A" Foreground="#05080E" FontWeight="Bold"
                            Margin="0,0,6,0" Click="StartBotBtn_Click"/>
                    <Button x:Name="StopBotBtn" Grid.Column="1" Content="■  STOP BOT" Height="44"
                            Background="#F2586B" Foreground="White" FontWeight="Bold"
                            Margin="6,0,0,0" Click="StopBotBtn_Click" IsEnabled="False"/>
                </Grid>

                <WrapPanel Margin="0,0,0,12">
                    <Button x:Name="RefreshBtn" Content="Refresh Status" Width="130" Height="36" Margin="0,0,8,8" Click="RefreshBtn_Click"/>
                    <Button x:Name="SyncConfigBtn" Content="Sync Config" Width="110" Height="36" Margin="0,0,8,8" Click="SyncConfigBtn_Click"/>
                    <Button x:Name="FetchWeaponsBtn" Content="Fetch Weapons" Width="125" Height="36" Margin="0,0,8,8" Click="FetchWeaponsBtn_Click"/>
                    <Button x:Name="DebugSnapshotBtn" Content="Debug Snapshot" Width="125" Height="36" Margin="0,0,8,8" Click="DebugSnapshotBtn_Click" IsEnabled="False"/>
                    <Button x:Name="ReconnectBtn" Content="Toggle Simulation" Width="140" Height="36" Click="SimulationBtn_Click"/>
                </WrapPanel>

                <TextBlock Text="Detected weapons" FontSize="12" Opacity="0.7"/>
                <ListBox x:Name="WeaponsList" Height="100" Background="Transparent" BorderThickness="0" Foreground="LightGray"/>
            </StackPanel>
        </Border>

        <!-- LIVE TELEMETRY -->
        <Border Grid.Row="0" Grid.Column="1" Background="#101826" CornerRadius="18" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Live Telemetry" FontWeight="Bold" FontSize="18" Margin="0,0,0,14"/>
                <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Healing" FontSize="12" Opacity="0.7"/>
                        <TextBlock x:Name="HealingStat" Text="0 HP/s" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Melee Kills" FontSize="12" Opacity="0.7"/>
                        <TextBlock x:Name="MeleeStat" Text="0" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Uptime" FontSize="12" Opacity="0.7"/>
                        <TextBlock x:Name="UptimeStat" Text="00:00:00" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Latency" FontSize="12" Opacity="0.7"/>
                        <TextBlock x:Name="PingStat" Text="0 ms" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </UniformGrid>
                <Border Grid.Row="2" Background="#0B111A" CornerRadius="12" Padding="12">
                    <Canvas x:Name="SparklineCanvas">
                        <Polyline x:Name="Sparkline" Stroke="#4ED9FF" StrokeThickness="3"/>
                    </Canvas>
                </Border>
            </Grid>
        </Border>

        <!-- ACTIVITY LOG (full-height, spans both columns) -->
        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#101826" CornerRadius="18" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Log toolbar -->
                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="Activity Log" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" DockPanel.Dock="Left" Margin="0,0,20,0"/>
                    <TextBlock x:Name="ScrollStateText" Text="Auto-scroll" FontSize="12" Opacity="0.6" VerticalAlignment="Center" DockPanel.Dock="Right" Margin="10,0,0,0"/>
                    <WrapPanel>
                        <Button x:Name="CopyLogBtn"    Content="Copy"       Width="80"  Height="32" Margin="0,0,6,4" Click="CopyLogBtn_Click"/>
                        <Button x:Name="ScrollLockBtn" Content="Lock Scroll" Width="105" Height="32" Margin="0,0,6,4" Click="ScrollLockBtn_Click"/>
                        <Button x:Name="FilterAllBtn"  Content="All"        Width="60"  Height="32" Margin="0,0,6,4" Click="FilterAllBtn_Click"/>
                        <Button x:Name="FilterOkBtn"   Content="OK"         Width="60"  Height="32" Margin="0,0,6,4" Click="FilterOkBtn_Click"/>
                        <Button x:Name="FilterErrBtn"  Content="ERR"        Width="60"  Height="32" Margin="0,0,6,4" Click="FilterErrBtn_Click"/>
                        <Button x:Name="FilterSyncBtn" Content="SYNC"       Width="60"  Height="32" Margin="0,0,6,4" Click="FilterSyncBtn_Click"/>
                        <Button x:Name="FilterWarnBtn" Content="WARN"       Width="60"  Height="32" Margin="0,0,6,4" Click="FilterWarnBtn_Click"/>
                        <TextBox x:Name="ActivitySearchBox" Width="200" Height="32" TextChanged="ActivitySearchBox_TextChanged"/>
                    </WrapPanel>
                </DockPanel>

                <!-- Log output -->
                <RichTextBox x:Name="LogOutput"
                             Grid.Row="1"
                             IsReadOnly="True"
                             Background="#0B111A"
                             BorderThickness="0"
                             Foreground="LightGray"
                             VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
