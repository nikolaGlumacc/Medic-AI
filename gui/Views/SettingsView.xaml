<UserControl x:Class="MedicAIGUI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="White">
    <Grid>
        <TabControl Background="Transparent" BorderThickness="0">
            <TabItem Header="Bot Brain" Background="Transparent" Foreground="Black">
                <ScrollViewer>
                    <StackPanel Margin="20">
                        <TextBlock Text="Retreat Health Threshold" Foreground="White" Margin="0,10,0,0"/>
                        <Slider Minimum="0" Maximum="150" Value="{Binding RetreatHealthThreshold, Mode=TwoWay}" Foreground="Red"/>

                        <TextBlock Text="Uber Pop Threshold" Foreground="White" Margin="0,10,0,0"/>
                        <Slider Minimum="0" Maximum="100" Value="{Binding UberPopThreshold, Mode=TwoWay}"/>

                        <CheckBox Content="Auto Uber" IsChecked="{Binding AutoUber, Mode=TwoWay}" Foreground="White" Margin="0,10,0,0"/>
                        <CheckBox Content="Prefer Melee on Retreat" IsChecked="{Binding PreferMeleeForRetreat, Mode=TwoWay}" Foreground="White" Margin="0,10,0,0"/>

                        <Button Content="Push Brain Config" Width="150" Height="40" Margin="0,20,0,0" x:Name="PushConfigBtn" Click="PushConfigBtn_Click" HorizontalAlignment="Left"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Spy Detection" Background="Transparent" Foreground="Black">
                <StackPanel Margin="20">
                    <TextBlock Text="Check Frequency (s)" Foreground="White"/>
                    <Slider Minimum="1" Maximum="30" Value="{Binding SpyCheckFrequency, Mode=TwoWay}"/>
                    <TextBlock Text="Alertness Duration (s)" Foreground="White" Margin="0,10,0,0"/>
                    <Slider Minimum="1" Maximum="60" Value="{Binding SpyAlertnessDuration, Mode=TwoWay}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Audio Cues" Background="Transparent" Foreground="Black"/>
            <TabItem Header="Voice Lines" Background="Transparent" Foreground="Black"/>
            <TabItem Header="Updates" Background="Transparent" Foreground="Black"/>
        </TabControl>
    </Grid>
</UserControl>
