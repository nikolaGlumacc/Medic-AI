<Window x:Class="MedicAIGUI.Views.VaccinatorOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vaccinator Overlay" Height="64" Width="64"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" IsHitTestVisible="False">
    <Grid>
        <Image x:Name="OverlayImage" Stretch="Uniform" Width="64" Height="64">
            <Image.Effect>
                <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.8"/>
            </Image.Effect>
        </Image>
    </Grid>
</Window>
