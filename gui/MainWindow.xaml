                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Screen Capture FPS Limit" Style="{StaticResource SectionLabel}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=ScreenCaptureFpsLimitSlider, StringFormat={}{0:0} FPS}" Style="{StaticResource SectionLabel}" />
                                                </Grid>
                                                <Slider x:Name="ScreenCaptureFpsLimitSlider" Minimum="5" Maximum="240" Value="60" TickFrequency="5" IsSnapToTickEnabled="True" />

                                                <TextBlock Text="YOLO Thread Priority" Style="{StaticResource SectionLabel}" />
                                                <ComboBox x:Name="YoloThreadPriorityCombo" ItemsSource="{Binding ThreadPriorityOptions}" SelectedIndex="1" />

                                                <Grid Margin="0,0,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="CPU Temperature Throttle Threshold" Style="{StaticResource SectionLabel}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=CpuThrottleThresholdSlider, StringFormat={}{0:0}°C}" Style="{StaticResource SectionLabel}" />
                                                </Grid>
                                                <Slider x:Name="CpuThrottleThresholdSlider" Minimum="40" Maximum="100" Value="85" TickFrequency="1" IsSnapToTickEnabled="True" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                <Grid Margin="0,0,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Throttle Amount When Overheating" Style="{StaticResource SectionLabel}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=ThrottleAmountSlider, StringFormat={}{0:0}%}" Style="{StaticResource SectionLabel}" />
                                                </Grid>
                                                <Slider x:Name="ThrottleAmountSlider" Minimum="0" Maximum="100" Value="40" TickFrequency="5" IsSnapToTickEnabled="True" />

                                                <CheckBox x:Name="WatchdogAutoRestartToggle" Content="Watchdog auto restart" IsChecked="True" />
                                                <CheckBox x:Name="Tf2WindowLockToggle" Content="TF2 window lock for dual monitors" IsChecked="True" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </TabItem>

                            <TabItem Header="Startup &amp; Shutdown">
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="0.9*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Margin="0,0,14,0" Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Startup Actions" Style="{StaticResource TitleText}" />
                                            <TextBlock Text="These toggles shape the launch sequence before gameplay logic takes over." Style="{StaticResource SectionLabel}" Margin="0,6,0,16" TextWrapping="Wrap" />

                                            <CheckBox x:Name="AutoSkipTf2IntroToggle" Content="Auto skip TF2 intro" IsChecked="True" />
                                            <CheckBox x:Name="AutoSelectMedicToggle" Content="Auto select Medic" IsChecked="True" />
                                            <CheckBox x:Name="AutoEquipLoadoutOnStartToggle" Content="Auto equip loadout on start" IsChecked="True" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Shutdown &amp; Restart" Style="{StaticResource TitleText}" />
                                            <TextBlock Text="Decide how the bot should wind down cleanly and how long the watchdog should wait before reviving the process." Style="{StaticResource SectionLabel}" Margin="0,6,0,16" TextWrapping="Wrap" />

                                            <TextBlock Text="Clean Shutdown Behavior" Style="{StaticResource SectionLabel}" />
                                            <ComboBox x:Name="CleanShutdownBehaviorCombo" ItemsSource="{Binding CleanShutdownOptions}" SelectedIndex="0" />

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Watchdog Restart Delay" Style="{StaticResource SectionLabel}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=WatchdogRestartDelaySlider, StringFormat={}{0:0}s}" Style="{StaticResource SectionLabel}" />
                                            </Grid>
                                            <Slider x:Name="WatchdogRestartDelaySlider" Minimum="1" Maximum="60" Value="8" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Updates">
                                <StackPanel Margin="0,8,0,0">
                                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                                        <StackPanel>
                                            <TextBlock Text="Update Center" Style="{StaticResource TitleText}" />
                                            <TextBlock Text="Current version, remote checks, one-click updates, rollback, and a compact changelog all live here." Style="{StaticResource SectionLabel}" Margin="0,6,0,16" TextWrapping="Wrap" />

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="180" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="Current Version" Style="{StaticResource SectionLabel}" />
                                                <TextBlock x:Name="VersionValueText" Grid.Column="1" Text="Loading..." />

                                                <TextBlock Grid.Row="1" Text="State" Style="{StaticResource SectionLabel}" Margin="0,12,0,0" />
                                                <TextBlock x:Name="UpdateStateText" Grid.Row="1" Grid.Column="1" Text="Checking local repository..." Margin="0,12,0,0" FontFamily="Bahnschrift SemiCondensed" FontSize="17" FontWeight="SemiBold" />

                                                <TextBlock Grid.Row="2" Text="Detail" Style="{StaticResource SectionLabel}" Margin="0,12,0,0" />
                                                <TextBlock x:Name="UpdateHintText" Grid.Row="2" Grid.Column="1" Text="Waiting for repository scan." Margin="0,12,0,0" TextWrapping="Wrap" />

                                                <TextBlock Grid.Row="3" Text="Repo Path" Style="{StaticResource SectionLabel}" Margin="0,12,0,0" />
                                                <TextBlock x:Name="RepoPathText" Grid.Row="3" Grid.Column="1" Text="Unavailable" Margin="0,12,0,0" TextWrapping="Wrap" />
                                            </Grid>

                                            <CheckBox x:Name="AutoCheckUpdatesOnLaunchToggle" Content="Auto check on launch" IsChecked="False" />

                                            <WrapPanel Margin="0,12,0,0">
                                                <Button x:Name="CheckUpdatesBtn" Content="Check Remote" Width="140" Margin="0,0,10,10" Click="CheckUpdatesBtn_Click" />
                                                <Button x:Name="UpdateBtn" Content="Install Update" Width="160" Margin="0,0,10,10" Click="UpdateBtn_Click" Style="{StaticResource PrimaryButtonStyle}" />
                                                <Button x:Name="RollbackBtn" Content="Rollback One Commit" Width="180" Margin="0,0,0,10" Click="RollbackBtn_Click" Style="{StaticResource DangerButtonStyle}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Changelog Viewer" Style="{StaticResource TitleText}" />
                                            <TextBlock Text="This shows the latest local commit history so the operator can see what changed before updating or rolling back." Style="{StaticResource SectionLabel}" Margin="0,6,0,14" TextWrapping="Wrap" />
                                            <TextBox x:Name="ChangelogViewer"
                                                     Height="300"
                                                     AcceptsReturn="True"
                                                     IsReadOnly="True"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto"
                                                     FontFamily="Cascadia Code"
                                                     Margin="0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </TabItem>

                            <TabItem Header="Loadout">
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.15*" />
                                        <ColumnDefinition Width="0.95*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Margin="0,0,14,0" Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Loadout Presets" Style="{StaticResource TitleText}" />
                                            <TextBlock Text="Edit the preset slots directly, then choose which one is live right now. Active preset weapons are mirrored into the config payload on sync and deploy." Style="{StaticResource SectionLabel}" Margin="0,6,0,16" TextWrapping="Wrap" />

                                            <TextBlock Text="Active Preset Selector" Style="{StaticResource SectionLabel}" />
                                            <ComboBox x:Name="ActivePresetSelector"
                                                      ItemsSource="{Binding LoadoutPresets}"
                                                      DisplayMemberPath="Name"
                                                      SelectedIndex="0" />

                                            <ListView x:Name="LoadoutPresetListView" Background="Transparent" BorderThickness="0" Height="395" ItemContainerStyle="{StaticResource ListBoxItemCardStyle}">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <TextBlock Text="Preset Name" Style="{StaticResource SectionLabel}" />
                                                            <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,10" />

                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel>
                                                                    <TextBlock Text="Primary Weapon" Style="{StaticResource SectionLabel}" />
                                                                    <ComboBox ItemsSource="{Binding DataContext.PrimaryWeaponOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              SelectedItem="{Binding PrimaryWeapon, Mode=TwoWay}"
                                                                              Margin="0,6,10,0" />
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="Secondary Weapon" Style="{StaticResource SectionLabel}" />
                                                                    <ComboBox ItemsSource="{Binding DataContext.SecondaryWeaponOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              SelectedItem="{Binding SecondaryWeapon, Mode=TwoWay}"
                                                                              Margin="0,6,10,0" />
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="2">
                                                                    <TextBlock Text="Melee Weapon" Style="{StaticResource SectionLabel}" />
                                                                    <ComboBox ItemsSource="{Binding DataContext.MeleeWeaponOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              SelectedItem="{Binding MeleeWeapon, Mode=TwoWay}"
                                                                              Margin="0,6,0,0" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <Border Margin="0,0,0,14" Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Auto Loadout Rules" Style="{StaticResource TitleText}" />
                                                <TextBlock Text="Tell the bot which preset to equip when the tracked teammate class changes." Style="{StaticResource SectionLabel}" Margin="0,6,0,14" TextWrapping="Wrap" />

                                                <ListView x:Name="AutoLoadoutRuleListView" Background="Transparent" BorderThickness="0" Height="290" SelectionMode="Single" ItemContainerStyle="{StaticResource ListBoxItemCardStyle}">
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel>
                                                                    <TextBlock Text="Teammate Class" Style="{StaticResource SectionLabel}" />
                                                                    <ComboBox ItemsSource="{Binding DataContext.TeammateClassOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              SelectedItem="{Binding TeammateClass, Mode=TwoWay}"
                                                                              Margin="0,6,10,0" />
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="Equip Preset" Style="{StaticResource SectionLabel}" />
                                                                    <ComboBox ItemsSource="{Binding DataContext.LoadoutPresets, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              SelectedItem="{Binding Preset, Mode=TwoWay}"
                                                                              DisplayMemberPath="Name"
                                                                              Margin="0,6,0,0" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>

                                                <WrapPanel Margin="0,12,0,0">
                                                    <Button Content="Add Rule" Width="110" Margin="0,0,10,10" Click="AddLoadoutRule_Click" Style="{StaticResource PrimaryButtonStyle}" />
                                                    <Button Content="Remove Selected" Width="150" Margin="0,0,0,10" Click="RemoveLoadoutRule_Click" Style="{StaticResource DangerButtonStyle}" />
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Preset Notes" Style="{StaticResource TitleText}" />
                                                <TextBlock Text="The active preset is the one that feeds the top-level primary, secondary, and melee weapon keys so the existing bot stays compatible." Style="{StaticResource SectionLabel}" Margin="0,6,0,10" TextWrapping="Wrap" />
                                                <TextBlock Text="Preset names are editable on purpose, so you can label them by push style, team comp, or map-specific pocket rules." Style="{StaticResource SectionLabel}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <!-- =============================================== -->
                            <!-- BOT BRAIN CONFIGURATION (NEW)                    -->
                            <!-- =============================================== -->
                            <TabItem Header="Bot Brain">
                                <Border Margin="0,8,0,0" Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Decision Thresholds" Style="{StaticResource TitleText}" />
                                        <TextBlock Text="These values control when the bot retreats, defends, or pops Uber. Sync to push changes to the running bot." Style="{StaticResource SectionLabel}" Margin="0,6,0,16" TextWrapping="Wrap" />

                                        <!-- Retreat Health Threshold -->
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Retreat health threshold" Style="{StaticResource SectionLabel}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=RetreatHealthThresholdSlider, StringFormat={}{0:0}%}" Style="{StaticResource SectionLabel}" />
                                        </Grid>
                                        <Slider x:Name="RetreatHealthThresholdSlider" Minimum="0" Maximum="100" Value="50" TickFrequency="5" IsSnapToTickEnabled="True" />

                                        <!-- Defend Enemy Distance -->
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Defend enemy distance (px)" Style="{StaticResource SectionLabel}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=DefendEnemyDistanceSlider, StringFormat={}{0:0} px}" Style="{StaticResource SectionLabel}" />
                                        </Grid>
                                        <Slider x:Name="DefendEnemyDistanceSlider" Minimum="50" Maximum="600" Value="300" TickFrequency="50" IsSnapToTickEnabled="True" />

                                        <!-- Uber Pop Threshold -->
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Auto-pop Uber threshold" Style="{StaticResource SectionLabel}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=UberPopThresholdSlider, StringFormat={}{0:0}%}" Style="{StaticResource SectionLabel}" />
                                        </Grid>
                                        <Slider x:Name="UberPopThresholdSlider" Minimum="50" Maximum="100" Value="95" TickFrequency="5" IsSnapToTickEnabled="True" />

                                        <!-- Checkboxes -->
                                        <CheckBox x:Name="PreferMeleeForRetreatToggle" Content="Prefer melee when retreating" Margin="0,10,0,5" IsChecked="True"/>
                                        <CheckBox x:Name="AutoHealToggle" Content="Auto-heal (hold M1 on target)" Margin="0,0,0,5" IsChecked="True"/>
                                        <CheckBox x:Name="AutoUberBrainToggle" Content="Auto-pop Uber when ready" Margin="0,0,0,5" IsChecked="True"/>
                                        <CheckBox x:Name="PriorityOnlyHealToggle" Content="Heal ONLY priority players (ignore others)" Margin="0,0,0,5" IsChecked="True"/>

                                        <!-- Sync Button -->
                                        <Button x:Name="SyncBrainConfigBtn" Content="Sync Brain Config to Bot" Click="SyncBrainConfigBtn_Click" Margin="0,15,0,5" Width="180" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                            </TabItem>

                        </TabControl>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="18,0,18,18" Background="#B210151E" CornerRadius="16" BorderBrush="#1FFFFFFF" BorderThickness="1">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusStripDot" Width="9" Height="9" Fill="IndianRed" />
                            <TextBlock Text="{Binding Text, ElementName=StatusLabel}" Margin="10,0,0,0" Style="{StaticResource SectionLabel}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding Text, ElementName=FollowModeLabel}" Margin="22,0,0,0" VerticalAlignment="Center" Style="{StaticResource SectionLabel}" />
                        <TextBlock Grid.Column="2" Text="{Binding Text, ElementName=UberMeterLabel}" Margin="22,0,0,0" VerticalAlignment="Center" Style="{StaticResource SectionLabel}" />
                        <TextBlock Grid.Column="3" Text="{Binding Text, ElementName=SessionTimer}" Margin="22,0,0,0" VerticalAlignment="Center" FontFamily="Bahnschrift SemiCondensed" FontSize="15" FontWeight="Bold" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>