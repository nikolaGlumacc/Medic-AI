<Window x:Class="MedicAIGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MedicAI"
        Width="1280"
        Height="820"
        MinWidth="1280"
        MinHeight="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#05080E"
        Foreground="#F6F7FB"
        FontFamily="Segoe UI Variable"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closing="Window_Closing">

    <Window.Resources>
        <Color x:Key="BaseBlack">#05080E</Color>
        <Color x:Key="BaseDeep">#0B1018</Color>
        <Color x:Key="PanelFill">#C9111620</Color>
        <Color x:Key="PanelRaised">#E1141B27</Color>
        <Color x:Key="SurfaceStroke">#31FFFFFF</Color>
        <Color x:Key="AccentHot">#F2586B</Color>
        <Color x:Key="AccentHotStrong">#FF7B8A</Color>
        <Color x:Key="AccentCool">#4ED9FF</Color>
        <Color x:Key="TextMain">#F7F9FC</Color>
        <Color x:Key="TextDim">#C7CED8</Color>
        <Color x:Key="TextHint">#8190A4</Color>

        <SolidColorBrush x:Key="WindowBrush" Color="{StaticResource BaseBlack}" />
        <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelFill}" />
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="{StaticResource PanelRaised}" />
        <SolidColorBrush x:Key="StrokeBrush" Color="{StaticResource SurfaceStroke}" />
        <SolidColorBrush x:Key="AccentHotBrush" Color="{StaticResource AccentHot}" />
        <SolidColorBrush x:Key="AccentHotStrongBrush" Color="{StaticResource AccentHotStrong}" />
        <SolidColorBrush x:Key="AccentCoolBrush" Color="{StaticResource AccentCool}" />
        <SolidColorBrush x:Key="TextMainBrush" Color="{StaticResource TextMain}" />
        <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDim}" />
        <SolidColorBrush x:Key="TextHintBrush" Color="{StaticResource TextHint}" />

        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF6C7B" Offset="0" />
            <GradientStop Color="{StaticResource AccentHot}" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PanelBorderGlowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#42F2586B" Offset="0" />
            <GradientStop Color="#1857D8FF" Offset="1" />
        </LinearGradientBrush>

        <DropShadowEffect x:Key="PanelShadow" Color="#D0000000" BlurRadius="26" ShadowDepth="10" Opacity="0.48" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FF000000" BlurRadius="4" ShadowDepth="0" Opacity="0.92" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextHintBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="MetricValueText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
        </Style>

        <Style x:Key="InsetCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#10151E" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="BorderBrush" Value="#24FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background" Value="#181F2B" />
            <Setter Property="BorderBrush" Value="#3AFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <Grid>
                                <Border CornerRadius="11" Margin="1" BorderBrush="#12FFFFFF" BorderThickness="1" />
                                <TextBlock Text="{TemplateBinding Content}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="SemiBold" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHotStrongBrush}" />
                                <Setter TargetName="Root" Property="Background" Value="#202836" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="#FFFFAAB3" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#311116" />
            <Setter Property="BorderBrush" Value="#77F2586B" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background" Value="#121824" />
            <Setter Property="BorderBrush" Value="#34FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,6,0,10" />
            <Setter Property="CaretBrush" Value="White" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background" Value="#121824" />
            <Setter Property="BorderBrush" Value="#34FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,6,0,10" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Margin" Value="0,6,0,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="52" Height="28">
                                <Border x:Name="Track" Background="#121824" CornerRadius="14" BorderBrush="#34FFFFFF" BorderThickness="1" />
                                <Ellipse x:Name="Thumb" Width="20" Height="20" Fill="#E7EBF2" Margin="4,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Text="{TemplateBinding Content}" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#283241" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentHotStrongBrush}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,4,0" />
                                <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource AccentHotBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,6,0,10" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="18">
                            <Border Height="8" CornerRadius="4" Background="#121824" BorderBrush="#293140" BorderThickness="1" VerticalAlignment="Center" />
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" BorderThickness="0" Background="{StaticResource AccentHotBrush}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="8" Background="{TemplateBinding Background}" CornerRadius="4" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18" Height="18" Background="#FFF5F7" BorderBrush="#FF000000" BorderThickness="1.5">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="{TemplateBinding BorderThickness}" />
                                                    <Ellipse Width="7" Height="7" Fill="{StaticResource AccentHotBrush}" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" BorderThickness="0" Background="Transparent">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="8" Background="{TemplateBinding Background}" CornerRadius="4" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavItemStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="#10151E" BorderBrush="#00000000" BorderThickness="1" CornerRadius="14" Padding="14,12">
                            <Grid>
                                <Border x:Name="AccentBar" Width="4" HorizontalAlignment="Left" CornerRadius="2" Background="{StaticResource AccentHotBrush}" Opacity="0" />
                                <TextBlock Text="{TemplateBinding Content}" Margin="16,0,0,0" FontFamily="Bahnschrift SemiCondensed" FontSize="15" FontWeight="SemiBold" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#35FFFFFF" />
                                <Setter TargetName="Root" Property="Background" Value="#141B27" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#171F2C" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHotStrongBrush}" />
                                <Setter TargetName="AccentBar" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ListBoxItemCardStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" Background="#10151E" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHotStrongBrush}" />
                                <Setter TargetName="Root" Property="Background" Value="#161E2A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Background="#10151E"
                                BorderBrush="#24FFFFFF"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                                        <Setter Property="FontSize" Value="14" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect" Value="{x:Null}" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#48FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#171F2C" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHotStrongBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
        </Style>
    </Window.Resources>

    <Grid PreviewMouseLeftButtonDown="WindowSurface_PreviewMouseLeftButtonDown">
        <Border Background="{StaticResource WindowBrush}" />
        <Ellipse Width="540" Height="540" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-180,-140,0" Fill="#24F2586B">
            <Ellipse.Effect>
                <BlurEffect Radius="140" />
            </Ellipse.Effect>
        </Ellipse>
        <Ellipse Width="620" Height="620" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-260,0,0,-260" Fill="#1457D8FF">
            <Ellipse.Effect>
                <BlurEffect Radius="170" />
            </Ellipse.Effect>
        </Ellipse>

        <Border Margin="20" Background="#CC070B11" CornerRadius="26" BorderBrush="{StaticResource PanelBorderGlowBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="74" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="54" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#A30C111A" CornerRadius="26,26,0,0" BorderBrush="#18FFFFFF" BorderThickness="0,0,0,1" />
                <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="24,0" MouseDown="TitleBar_MouseDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="48" Height="48" CornerRadius="14" Background="#141B28" BorderBrush="#46F2586B" BorderThickness="1.5">
                            <TextBlock Text="M" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Bahnschrift SemiCondensed" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentHotBrush}" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="MedicAI Command Deck" FontFamily="Bahnschrift SemiCondensed" FontSize="22" FontWeight="Bold" />
                            <TextBlock Text="Medic-focused bot control, live triage, and real repo updates" Style="{StaticResource SectionLabel}" Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MinimizeBtn" Width="44" Height="34" Content="_" Margin="0,0,10,0" Click="MinimizeBtn_Click" />
                        <Button x:Name="CloseBtn" Width="44" Height="34" Content="X" Click="CloseBtn_Click" Style="{StaticResource DangerButtonStyle}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Grid.Column="0" Margin="18,12,12,14" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="MedicAI" FontFamily="Bahnschrift SemiCondensed" FontSize="30" FontWeight="Bold" />
                            <TextBlock Text="Command, tune, and monitor the Medic bot without hiding the real knobs you asked for." Style="{StaticResource SectionLabel}" Margin="0,6,0,0" TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,22,0,0">
                            <RadioButton x:Name="DashboardTabBtn" Content="Dashboard" Style="{StaticResource NavItemStyle}" IsChecked="True" Checked="NavTab_Checked" />
                            <RadioButton x:Name="PriorityTabBtn" Content="Priority &amp; Players" Style="{StaticResource NavItemStyle}" Checked="NavTab_Checked" />
                            <RadioButton x:Name="SettingsTabBtn" Content="Settings" Style="{StaticResource NavItemStyle}" Checked="NavTab_Checked" />
                        </StackPanel>

                        <Border Grid.Row="2" Background="#121824" CornerRadius="16" BorderBrush="#26FFFFFF" BorderThickness="1" Padding="16" VerticalAlignment="Bottom">
                            <StackPanel>
                                <TextBlock Text="Live Link" Style="{StaticResource SectionLabel}" />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                                    <Ellipse x:Name="StatusDot" Width="11" Height="11" Fill="IndianRed" />
                                    <TextBlock x:Name="StatusLabel" Text="Offline" FontFamily="Bahnschrift SemiCondensed" FontSize="17" FontWeight="SemiBold" Margin="10,0,0,0" />
                                </StackPanel>
                                <TextBlock x:Name="FollowModeLabel" Text="Mode: STANDBY" Margin="0,12,0,0" />
                                <TextBlock x:Name="UberMeterLabel" Text="Uber: 0%" Margin="0,6,0,0" />
                                <TextBlock Text="Status stays visible even while you are buried in tabs, logs, or live priority edits." Style="{StaticResource SectionLabel}" Margin="0,14,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <ScrollViewer x:Name="DashboardScroller" Grid.Row="1" Grid.Column="1" Margin="10,12,18,14" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Margin="0,0,14,14" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Quick Actions" Style="{StaticResource TitleText}" />
                                    <TextBlock Text="Deploy, stop, reconnect, and resync from a clean front page while the full connection tab holds the deeper wiring." Style="{StaticResource SectionLabel}" Margin="0,6,0,14" TextWrapping="Wrap" />

                                    <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Endpoint" Style="{StaticResource SectionLabel}" />
                                                <TextBlock FontFamily="Bahnschrift SemiCondensed" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0">
                                                    <Run Text="{Binding Text, ElementName=BotIpInput}" />
                                                    <Run Text=":" />
                                                    <Run Text="{Binding Text, ElementName=PortInput}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding Value, ElementName=ConnectionTimeoutSlider, StringFormat=Timeout: {0:0}s}" Margin="0,6,0,0" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#261722" BorderBrush="#55F2586B" BorderThickness="1" CornerRadius="10" Padding="12,6" VerticalAlignment="Center" Margin="12,0,0,0">
                                                <TextBlock Text="{Binding Text, ElementName=StatusLabel}" FontFamily="Bahnschrift SemiCondensed" FontWeight="Bold" Foreground="{StaticResource AccentHotBrush}" />
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <UniformGrid Columns="2">
                                        <Button x:Name="ConnectBtn" Content="Connect" Margin="0,0,10,10" Click="ConnectBtn_Click" />
                                        <Button x:Name="StartBtn" Content="Deploy Medic" Margin="0,0,0,10" Click="StartBtn_Click" Style="{StaticResource PrimaryButtonStyle}" />
                                        <Button x:Name="SendConfigBtn" Content="Sync Config" Margin="0,0,10,0" Click="SendConfigBtn_Click" />
                                        <Button x:Name="StopBtn" Content="Stop Bot" Click="StopBtn_Click" Style="{StaticResource DangerButtonStyle}" />
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" Margin="0,0,0,14" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Behavior Snapshot" Style="{StaticResource TitleText}" />
                                    <TextBlock Text="A quick read of the active preset and the biggest behavior switches without opening the deeper tuning tabs." Style="{StaticResource SectionLabel}" Margin="0,6,0,14" TextWrapping="Wrap" />

                                    <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Active Preset" Style="{StaticResource SectionLabel}" />
                                            <TextBlock Text="{Binding SelectedItem.Name, ElementName=ActivePresetSelector, FallbackValue=Default Medigun}" FontFamily="Bahnschrift SemiCondensed" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource InsetCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedItem, ElementName=DefaultModeOnStartupCombo, StringFormat=Startup mode: {0}}" />
                                            <TextBlock Text="{Binding Value, ElementName=FollowDistanceSlider, StringFormat=Default follow distance: {0:0} u}" Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding Value, ElementName=SpyCheckFreqSlider, StringFormat=Spy check frequency: {0:0}s}" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding IsChecked, ElementName=AutoReconnectCB, StringFormat=Auto reconnect: {0}}" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding IsChecked, ElementName=AutoPopToggle, StringFormat=Auto pop: {0}}" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Margin="0,0,14,0" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Live Session" Style="{StaticResource TitleText}" />
                                    <TextBlock Text="Session time, melee picks, healing output, and current focus stay front and center while the bot is running." Style="{StaticResource SectionLabel}" Margin="0,6,0,14" TextWrapping="Wrap" />

                                    <UniformGrid Columns="3" Margin="0,0,0,14">
                                        <Border Margin="0,0,10,0" Style="{StaticResource InsetCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Session" Style="{StaticResource SectionLabel}" />
                                                <TextBlock x:Name="SessionTimer" Text="00:00:00" Style="{StaticResource MetricValueText}" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="0,0,10,0" Style="{StaticResource InsetCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Melee Picks" Style="{StaticResource SectionLabel}" />
                                                <TextBlock x:Name="MeleeKillsStatLabel" Text="Melee picks: 0" FontFamily="Bahnschrift SemiCondensed" FontSize="18" FontWeight="SemiBold" Margin="0,10,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource InsetCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Healing Output" Style="{StaticResource SectionLabel}" />
                                                <TextBlock x:Name="TotalHealingStatLabel" Text="Healing output: 0 HP" FontFamily="Bahnschrift SemiCondensed" FontSize="18" FontWeight="SemiBold" Margin="0,10,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Border Style="{StaticResource InsetCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Current Focus" Style="{StaticResource SectionLabel}" />
                                            <TextBlock Text="{Binding Text, ElementName=FollowModeLabel}" Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding Text, ElementName=UberMeterLabel}" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding Text, ElementName=StatusLabel}" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Respawn Watch" Style="{StaticResource TitleText}" />
                                    <TextBlock Text="This remains read-only on purpose, so the list is fast to scan and impossible to fat-finger mid-round." Style="{StaticResource SectionLabel}" Margin="0,6,0,14" TextWrapping="Wrap" />

                                    <ListView x:Name="RespawnTimerList" Background="Transparent" BorderThickness="0" Height="246" ItemContainerStyle="{StaticResource ListBoxItemCardStyle}">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="42" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="24" Height="24" Stroke="{Binding Color}" StrokeThickness="3" VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayText}" FontFamily="Bahnschrift SemiCondensed" FontSize="15" FontWeight="SemiBold" />
                                                        <TextBlock Text="Respawning" Style="{StaticResource SectionLabel}" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Activity Feed" Style="{StaticResource TitleText}" />
                                <TextBlock Text="High-signal logs only, with clean tags for errors, sync events, reconnects, and update activity." Style="{StaticResource SectionLabel}" Margin="0,6,0,14" TextWrapping="Wrap" />
                                <RichTextBox x:Name="ActivityLog"
                                             IsReadOnly="True"
                                             Background="#0E131C"
                                             BorderBrush="#24FFFFFF"
                                             BorderThickness="1"
                                             Padding="12"
                                             Height="220"
                                             Foreground="{StaticResource TextDimBrush}"
                                             FontFamily="Cascadia Code">
                                    <FlowDocument />
                                </RichTextBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="PriorityScroller" Grid.Row="1" Grid.Column="1" Margin="10,12,18,14" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.18*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Margin="0,0,14,0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Priority &amp; Players" Style="{StaticResource TitleText}" />
                                <TextBlock Text="Tier slots, manual adds, reordering, and per-player overrides all live together so you can rebuild the heal stack quickly." Style="{StaticResource SectionLabel}" Margin="0,6,0,14" TextWrapping="Wrap" />

                                <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Priority Tier Slots" Style="{StaticResource TitleText}" />
                                        <TextBlock Text="Use these as fast-entry slots for the three names you care about most this round." Style="{StaticResource SectionLabel}" Margin="0,6,0,12" TextWrapping="Wrap" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Tier 1" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" />
                                            <TextBox x:Name="Tier1PriorityInput" Grid.Column="1" Margin="0,0,0,8" />

                                            <TextBlock Grid.Row="1" Text="Tier 2" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" />
                                            <TextBox x:Name="Tier2PriorityInput" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" />

                                            <TextBlock Grid.Row="2" Text="Tier 3" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" />
                                            <TextBox x:Name="Tier3PriorityInput" Grid.Row="2" Grid.Column="1" Margin="0" />
                                        </Grid>

                                        <Button Content="Apply Tier Slots" Width="150" Margin="0,14,0,0" Click="ApplyTierSlots_Click" Style="{StaticResource PrimaryButtonStyle}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Manual Add" Style="{StaticResource TitleText}" />
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="PriorityNameInput" Margin="0,0,10,0" />
                                            <ComboBox x:Name="TierInput" Grid.Column="1" ItemsSource="{Binding PriorityTierOptions}" SelectedIndex="0" Margin="0,0,10,0" />
                                            <Button x:Name="AddPriority" Grid.Column="2" Content="Add Target" Width="110" Click="AddPriority_Click" Style="{StaticResource PrimaryButtonStyle}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <ListView x:Name="PriorityListView" Background="Transparent" BorderThickness="0" Height="390" SelectionMode="Single" ItemContainerStyle="{StaticResource ListBoxItemCardStyle}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0" />
                                                        <TextBlock Style="{StaticResource SectionLabel}" Margin="0,6,0,0">
                                                            <Run Text="Deaths " />
                                                            <Run Text="{Binding Deaths}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" Background="#261722" BorderBrush="#55F2586B" BorderThickness="1" CornerRadius="10" Padding="10,5" VerticalAlignment="Center" Margin="12,0,0,0">
                                                        <TextBlock Text="{Binding StatusIcon}" FontFamily="Bahnschrift SemiCondensed" FontWeight="Bold" Foreground="{StaticResource AccentHotBrush}" />
                                                    </Border>
                                                </Grid>

                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="170" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="Tier" Style="{StaticResource SectionLabel}" />
                                                        <ComboBox ItemsSource="{Binding DataContext.PriorityTierOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding Tier, Mode=TwoWay}"
                                                                  Margin="0" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                        <TextBlock Text="Follow Override" Style="{StaticResource SectionLabel}" />
                                                        <TextBox Text="{Binding FollowDistanceOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                                        <TextBlock Text="Passive Override" Style="{StaticResource SectionLabel}" />
                                                        <ComboBox ItemsSource="{Binding DataContext.PassiveOverrideOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding PassiveModeOverride, Mode=TwoWay}"
                                                                  Margin="0" />
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="3" Text="Use 0 follow override to keep the default distance from the follow behavior tab." Style="{StaticResource SectionLabel}" Margin="12,22,0,0" TextWrapping="Wrap" />
                                                </Grid>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <WrapPanel Margin="0,12,0,0">
                                    <Button x:Name="RemovePriority" Content="Remove Selected" Width="150" Margin="0,0,10,10" Click="RemovePriority_Click" Style="{StaticResource DangerButtonStyle}" />
                                    <Button Content="Move Up" Width="110" Margin="0,0,10,10" Click="MovePriorityUp_Click" />
                                    <Button Content="Move Down" Width="120" Margin="0,0,0,10" Click="MovePriorityDown_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <Border Margin="0,0,0,14" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Whitelist" Style="{StaticResource TitleText}" />
                                    <TextBlock Text="Protected names stay visible here, with optional scoreboard-assisted updates when the round context changes." Style="{StaticResource SectionLabel}" Margin="0,6,0,14" TextWrapping="Wrap" />

                                    <CheckBox x:Name="AutoWhitelistDetectionCheckBox" Content="Auto whitelist detection from scoreboard" IsChecked="True" />

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBox x:Name="WhitelistInput" Width="220" Margin="0,0,10,0" />
                                        <Button x:Name="AddWhitelist" Content="Add" Width="74" Margin="0,0,8,0" Click="AddWhitelist_Click" Style="{StaticResource PrimaryButtonStyle}" />
                                        <Button x:Name="RemoveWhitelist" Content="Remove" Width="86" Click="RemoveWhitelist_Click" Style="{StaticResource DangerButtonStyle}" />
                                    </StackPanel>

                                    <ListBox x:Name="WhitelistBox" Height="190" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource ListBoxItemCardStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,0,14" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Blacklist" Style="{StaticResource TitleText}" />
                                    <TextBlock Text="Hostile names and one-shot bans stay easy to add and easy to prune without digging through unrelated settings." Style="{StaticResource SectionLabel}" Margin="0,6,0,14" TextWrapping="Wrap" />

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBox x:Name="BlacklistInput" Width="220" Margin="0,0,10,0" />
                                        <Button x:Name="AddBlacklist" Content="Add" Width="74" Margin="0,0,8,0" Click="AddBlacklist_Click" Style="{StaticResource PrimaryButtonStyle}" />
                                        <Button x:Name="RemoveBlacklist" Content="Remove" Width="86" Click="RemoveBlacklist_Click" Style="{StaticResource DangerButtonStyle}" />
                                    </StackPanel>

                                    <Button x:Name="QuickBanBtn" Content="Quick Ban" Width="120" Margin="0,0,0,12" Click="QuickBanBtn_Click" Style="{StaticResource DangerButtonStyle}" />
                                    <ListBox x:Name="BlacklistBox" Height="190" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource ListBoxItemCardStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Override Notes" Style="{StaticResource TitleText}" />
                                    <TextBlock Text="Tier order matters because the bot walks the list in order. Use the move buttons to change intent without retyping names." Style="{StaticResource SectionLabel}" Margin="0,6,0,10" TextWrapping="Wrap" />
                                    <TextBlock Text="Passive override is meant for edge cases like a pocket that should only be shadowed loosely, not a global mode switch." Style="{StaticResource SectionLabel}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <ScrollViewer x:Name="SettingsScroller" Grid.Row="1" Grid.Column="1" Margin="10,12,18,14" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Deep Configuration" FontFamily="Bahnschrift SemiCondensed" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="Each tab holds a real group of controls instead of fake filler, and everything here is included in the config payload the GUI sends." Style="{StaticResource SectionLabel}" Margin="0,6,0,18" TextWrapping="Wrap" />

                        <TabControl x:Name="SettingsTabControl" Background="Transparent" BorderThickness="0">
                            <TabItem Header="Connection">
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="0.9*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Margin="0,0,14,0" Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Connection Settings" Style="{StaticResource TitleText}" />
                                            <TextBlock Text="Point the GUI at the bot host, decide how aggressive reconnecting should be, and verify the socket path before you deploy." Style="{StaticResource SectionLabel}" Margin="0,6,0,16" TextWrapping="Wrap" />

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Laptop IP Address" Style="{StaticResource SectionLabel}" />
                                                    <TextBox x:Name="BotIpInput" Text="127.0.0.1" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                    <TextBlock Text="Port Number" Style="{StaticResource SectionLabel}" />
                                                    <TextBox x:Name="PortInput" Text="8765" />
                                                </StackPanel>
                                            </Grid>

                                            <CheckBox x:Name="AutoReconnectCB" Content="Auto reconnect if the websocket drops" IsChecked="True" />

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Connection Timeout Duration" Style="{StaticResource SectionLabel}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=ConnectionTimeoutSlider, StringFormat={}{0:0}s}" Style="{StaticResource SectionLabel}" />
                                            </Grid>
                                            <Slider x:Name="ConnectionTimeoutSlider" Minimum="2" Maximum="20" Value="6" TickFrequency="1" IsSnapToTickEnabled="True" />

                                            <WrapPanel Margin="0,12,0,0">
                                                <Button Content="Test Connection" Width="150" Margin="0,0,10,10" Click="TestConnectionBtn_Click" />
                                                <Button Content="Connect / Disconnect" Width="170" Margin="0,0,0,10" Click="ConnectBtn_Click" Style="{StaticResource PrimaryButtonStyle}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <Border Margin="0,0,0,14" Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Live Summary" Style="{StaticResource TitleText}" />
                                                <TextBlock Text="{Binding Text, ElementName=StatusLabel}" FontFamily="Bahnschrift SemiCondensed" FontSize="20" FontWeight="Bold" Margin="0,8,0,0" />
                                                <TextBlock Text="{Binding Text, ElementName=FollowModeLabel}" Margin="0,8,0,0" />
                                                <TextBlock Text="{Binding Value, ElementName=ConnectionTimeoutSlider, StringFormat=Handshake timeout: {0:0}s}" Margin="0,4,0,0" />
                                                <TextBlock Text="{Binding IsChecked, ElementName=AutoReconnectCB, StringFormat=Reconnect enabled: {0}}" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Why This Lives Here" Style="{StaticResource TitleText}" />
                                                <TextBlock Text="Connection settings now have their own tab because they drive deployment reliability, not gameplay logic. That keeps the dashboard lighter during actual matches." Style="{StaticResource SectionLabel}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Follow Behavior">
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Margin="0,0,14,0" Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Distance Control" Style="{StaticResource TitleText}" />
                                            <TextBlock Text="These sliders handle the basic spacing profile for default, active, passive, and escort movement." Style="{StaticResource SectionLabel}" Margin="0,6,0,14" TextWrapping="Wrap" />

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Default Follow Distance" Style="{StaticResource SectionLabel}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=FollowDistanceSlider, StringFormat={}{0:0} u}" Style="{StaticResource SectionLabel}" />
                                            </Grid>
                                            <Slider x:Name="FollowDistanceSlider" Minimum="0" Maximum="200" Value="50" TickFrequency="10" IsSnapToTickEnabled="True" />

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Active Mode Follow Distance" Style="{StaticResource SectionLabel}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=ActiveModeFollowDistanceSlider, StringFormat={}{0:0} u}" Style="{StaticResource SectionLabel}" />
                                            </Grid>
                                            <Slider x:Name="ActiveModeFollowDistanceSlider" Minimum="0" Maximum="220" Value="60" TickFrequency="10" IsSnapToTickEnabled="True" />

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Passive Mode Follow Distance" Style="{StaticResource SectionLabel}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=PassiveModeFollowDistanceSlider, StringFormat={}{0:0} u}" Style="{StaticResource SectionLabel}" />
                                            </Grid>
                                            <Slider x:Name="PassiveModeFollowDistanceSlider" Minimum="0" Maximum="220" Value="80" TickFrequency="10" IsSnapToTickEnabled="True" />

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Escort Mode Follow Distance" Style="{StaticResource SectionLabel}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=EscortModeFollowDistanceSlider, StringFormat={}{0:0} u}" Style="{StaticResource SectionLabel}" />
                                            </Grid>
                                            <Slider x:Name="EscortModeFollowDistanceSlider" Minimum="0" Maximum="240" Value="45" TickFrequency="10" IsSnapToTickEnabled="True" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Recovery &amp; Navigation" Style="{StaticResource TitleText}" />
                                            <TextBlock Text="These values define how tolerant the bot should be of chaos, how long search mode lasts, and when rerouting kicks in." Style="{StaticResource SectionLabel}" Margin="0,6,0,14" TextWrapping="Wrap" />

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Erratic Movement Threshold" Style="{StaticResource SectionLabel}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=ErraticMovementThresholdSlider, StringFormat={}{0:0}%}" Style="{StaticResource SectionLabel}" />
                                            </Grid>
                                            <Slider x:Name="ErraticMovementThresholdSlider" Minimum="0" Maximum="100" Value="45" TickFrequency="5" IsSnapToTickEnabled="True" />

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Search Mode Timeout Before Returning To Spawn" Style="{StaticResource SectionLabel}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=SearchModeTimeoutSlider, StringFormat={}{0:0}s}" Style="{StaticResource SectionLabel}" />
                                            </Grid>
                                            <Slider x:Name="SearchModeTimeoutSlider" Minimum="2" Maximum="30" Value="15" TickFrequency="1" IsSnapToTickEnabled="True" />

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Stuck Detection Sensitivity" Style="{StaticResource SectionLabel}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=StuckDetectionSensitivitySlider, StringFormat={}{0:0}%}" Style="{StaticResource SectionLabel}" />
                                            </Grid>
                                            <Slider x:Name="StuckDetectionSensitivitySlider" Minimum="0" Maximum="100" Value="55" TickFrequency="5" IsSnapToTickEnabled="True" />

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Retry Attempts Before Rerouting" Style="{StaticResource SectionLabel}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=StuckDetectionRetrySlider, StringFormat={}{0:0}}" Style="{StaticResource SectionLabel}" />
                                            </Grid>
                                            <Slider x:Name="StuckDetectionRetrySlider" Minimum="1" Maximum="10" Value="3" TickFrequency="1" IsSnapToTickEnabled="True" />

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Ledge Correction Sensitivity" Style="{StaticResource SectionLabel}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=LedgeCorrectionSensitivitySlider, StringFormat={}{0:0}%}" Style="{StaticResource SectionLabel}" />
                                            </Grid>
                                            <Slider x:Name="LedgeCorrectionSensitivitySlider" Minimum="0" Maximum="100" Value="40" TickFrequency="5" IsSnapToTickEnabled="True" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Uber">
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="0.9*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Margin="0,0,14,0" Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Uber Logic" Style="{StaticResource TitleText}" />
                                            <TextBlock Text="Choose whether the bot should hold, suggest, or pop Uber, then tune the edge-case rules around dead priorities and defensive reactions." Style="{StaticResource SectionLabel}" Margin="0,6,0,16" TextWrapping="Wrap" />

                                            <CheckBox x:Name="AutoPopToggle" Content="Auto pop" IsChecked="True" />

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Auto Pop Health Threshold" Style="{StaticResource SectionLabel}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=AutoPopHealthThresholdSlider, StringFormat={}{0:0} HP}" Style="{StaticResource SectionLabel}" />
                                            </Grid>
                                            <Slider x:Name="AutoPopHealthThresholdSlider" Minimum="1" Maximum="150" Value="30" TickFrequency="5" IsSnapToTickEnabled="True" />

                                            <CheckBox x:Name="ManualOnlyToggle" Content="Manual only" />
                                            <CheckBox x:Name="UberSuggestionAudioCueToggle" Content="Uber suggestion audio cue while pushing" IsChecked="True" />
                                            <CheckBox x:Name="HoldUberIfPriorityDeadToggle" Content="Hold Uber if priority is dead" IsChecked="True" />
                                            <CheckBox x:Name="DefensiveUberToggle" Content="Defensive Uber if enemy Uber is detected" IsChecked="True" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Behavior Summary" Style="{StaticResource TitleText}" />
                                            <TextBlock Text="Manual only wins over auto pop. If manual only is off, the GUI still sends a compatible legacy Uber behavior string for the current bot runtime." Style="{StaticResource SectionLabel}" Margin="0,6,0,14" TextWrapping="Wrap" />
                                            <Border Style="{StaticResource InsetCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding IsChecked, ElementName=AutoPopToggle, StringFormat=Auto pop enabled: {0}}" />
                                                    <TextBlock Text="{Binding IsChecked, ElementName=ManualOnlyToggle, StringFormat=Manual only: {0}}" Margin="0,6,0,0" />
                                                    <TextBlock Text="{Binding Value, ElementName=AutoPopHealthThresholdSlider, StringFormat=Health threshold: {0:0} HP}" Margin="0,6,0,0" />
                                                    <TextBlock Text="{Binding IsChecked, ElementName=DefensiveUberToggle, StringFormat=Defensive pop: {0}}" Margin="0,6,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Spy Detection">
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

